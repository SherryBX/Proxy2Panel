[Unit]
Description=Proxy Admin
After=network.target xr.service

[Service]
Type=simple
WorkingDirectory=/opt/proxy-admin/backend
EnvironmentFile=/opt/proxy-admin/.env
ExecStart=/opt/proxy-admin/backend/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8781
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
